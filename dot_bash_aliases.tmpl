alias clc='clear'
alias cls='clear'
alias start='nautilus'
alias myip="ifconfig | sed -En 's/127.0.0.1//;s/.*inet (addr:)?(([0-9]*\.){3}[0-9]*).*/\2/p'"
alias hgrep="history | grep"
alias fd='fdfind'
alias weather="curl wttr.in/?2Fn"

alias clcf="clear && fastfetch"
alias bonsai="cbonsai -l -t 0.04 -M 13 -L 76 -i -p"

{{- if eq .chezmoi.hostname "ETREL-90085" }}
alias qli='qasectl'
{{- end }}

# Pretify ip output
alias ip='ip -color=auto'

# Show DNS used
showdns() { nmcli device show "$1" | grep IP4.DNS; }

# Taken from: https://www.hardscrabble.net/2023/my-tmux-aliases/
# Attach to the last session - kinda
alias 't'='tmux new-session -A -s "$(basename $PWD) $(echo $PWD | shasum -a 256 | cut -c1-4)"'
# list sessions
alias 'tl'="tmux list-sessions -F '#{?session_attached,A, } #{s/ [a-f0-9][a-f0-9][a-f0-9][a-f0-9]$//:session_name}' 2>/dev/null || echo 'no sessions'"
alias 'ta'='tmux attach-session'
alias 'to'='tmux attach-session -t'




